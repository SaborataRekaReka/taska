# Common
NODE_ENV=development

# Docker infra
POSTGRES_DB=taska
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL_DOCKER=postgresql://postgres:postgres@postgres:5432/taska
REDIS_URL_DOCKER=redis://redis:6379

# API
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taska
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
GOOGLE_CLIENT_ID=change_me
GOOGLE_CLIENT_SECRET=change_me
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_FRONTEND_CALLBACK_URL=http://localhost:5173/auth/google/callback
OPENAI_API_KEY=change_me
OPENAI_MODEL_CHAT=gpt-4.1-mini
OPENAI_MODEL_PLAN=gpt-4.1-mini

# Frontend
EXPO_PUBLIC_API_URL=http://localhost:3000
