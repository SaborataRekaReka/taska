generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum HistoryEntityType {
  LIST
  TASK
  SUBTASK
  AI_OPERATION
}

enum HistoryActionType {
  CREATED
  UPDATED
  DELETED
  RESTORED
  AI_EXECUTED
  AI_UNDONE
}

enum AiOperationStatus {
  PLANNED
  CONFIRMED
  EXECUTED
  UNDONE
  FAILED
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique
  passwordHash   String?
  displayName    String?
  provider       AuthProvider @default(LOCAL)
  providerUserId String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  lists          List[]
  tasks          Task[]
  subtasks       Subtask[]
  historyEvents  History[]
  aiOperations   AiOperation[]
  preferences    UserPreferences?

  @@index([provider, providerUserId])
}

model UserPreferences {
  id            String   @id @default(cuid())
  userId        String   @unique
  dayColors     String?
  dayEnergy     Int      @default(11)
  dayMood       Int      @default(3)
  dayWishes     String?
  isMyDaySaved  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model List {
  id          String    @id @default(cuid())
  userId      String
  name        String
  isDefault   Boolean   @default(false)
  order       Int       @default(0)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@unique([userId, name])
  @@index([userId, deletedAt])
}

model Task {
  id          String       @id @default(cuid())
  userId      String
  listId      String?
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  deadline    DateTime?
  status      TaskStatus   @default(TODO)
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  list        List?        @relation(fields: [listId], references: [id], onDelete: SetNull)
  subtasks    Subtask[]

  @@index([userId, status, deletedAt])
  @@index([listId])
}

model Subtask {
  id            String      @id @default(cuid())
  userId        String
  taskId        String
  parentTaskId  String?
  title         String
  status        TaskStatus  @default(TODO)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  task          Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, taskId])
}

model History {
  id            String            @id @default(cuid())
  userId        String
  entityType    HistoryEntityType
  entityId      String
  actionType    HistoryActionType
  payload       Json
  createdAt     DateTime          @default(now())

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([entityType, entityId, createdAt])
}

model AiOperation {
  id             String            @id @default(cuid())
  userId         String
  operationType  String
  prompt         String
  planPayload    Json
  status         AiOperationStatus @default(PLANNED)
  executedAt     DateTime?
  undoneAt       DateTime?
  createdAt      DateTime          @default(now())

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}
